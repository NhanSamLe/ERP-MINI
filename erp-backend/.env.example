# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8888
NODE_ENV=production

# ─── Database (RDS MySQL trên AWS) ───────────────────────────────────────────
# Lấy các giá trị này từ AWS RDS → Endpoint
DB_HOST=your-rds-endpoint.xxxxxx.ap-southeast-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASS=CHANGE_ME_strong_password
DB_NAME=erp_mini_database

# ─── JWT (ĐỔI thành chuỗi random dài khi lên production) ──────────────────────
JWT_SECRET=CHANGE_ME_random_long_string_1
JWT_REFRESH_SECRET=CHANGE_ME_random_long_string_2
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
SALT_ROUNDS=10

# ─── CORS & Frontend (domain thật sau khi deploy) ────────────────────────────
# Nhiều domain phân tách bằng dấu phẩy
CORS_ORIGINS=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com

# ─── Email (Gmail App Password) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_gmail_app_password

# ─── Cloudinary (lưu file/ảnh) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── LLM / AI Chatbot ────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-proj-your-key
LLM_TIMEOUT_MS=30000
CHATBOT_CONTEXT_WINDOW=20
APP_BASE_URL=https://your-backend-domain.com/api
USE_MOCK_LLM=false

# ─── AI Narrative ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key
OPENAI_MODEL=gpt-4o-mini
NARRATIVE_CACHE_TTL=604800

# ─── Qdrant (vector DB — dùng Qdrant Cloud free tier) ────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# ─── Ollama (LLM local — KHÔNG dùng trên AWS free, để trống) ─────────────────
OLLAMA_HOST=http://localhost:11434
